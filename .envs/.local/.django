# General
# ------------------------------------------------------------------------------
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery
# ------------------------------------------------------------------------------

# Flower
CELERY_FLOWER_USER=admin
CELERY_FLOWER_PASSWORD=admin123

# Aivus Authentication
# ------------------------------------------------------------------------------
HMAC_SECRET=local-hmac-secret-for-development
API_KEY=local-api-key-for-development

DJANGO_DEBUG=True
DEBUG=True

# GCP Storage (optional - if empty, local filesystem will be used)
# ------------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/app/gcs-credentials.json
DJANGO_GCP_STORAGE_BUCKET_NAME=aivus-production-media
# LLM (Vertex AI / Gemini)
# ------------------------------------------------------------------------------
# WARNING: The previously exposed OpenAI key MUST be revoked at
# https://platform.openai.com/api-keys
GOOGLE_CLOUD_PROJECT=pioneering-flag-476313-u2
GOOGLE_CLOUD_LOCATION=us-central1
# Optional: separate service account JSON for Vertex AI.
# If empty, Application Default Credentials are used (same SA as GCS storage).
VERTEX_CREDENTIALS_PATH=/app/vertex-credentials.json
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
