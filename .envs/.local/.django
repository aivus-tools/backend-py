# General
# ------------------------------------------------------------------------------
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery
# ------------------------------------------------------------------------------

# Flower
CELERY_FLOWER_USER=admin
CELERY_FLOWER_PASSWORD=admin123

# Aivus Authentication
# ------------------------------------------------------------------------------
HMAC_SECRET=local-hmac-secret-for-development
API_KEY=local-api-key-for-development
WIX_WEBHOOK_SECRET=local-dev-wix-secret
WIX_EXTRA_ALLOWED_HOSTS=host.docker.internal

DJANGO_DEBUG=True
DEBUG=True

# GCP Storage (optional - if empty, local filesystem will be used)
# ------------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/app/gcs-credentials.json
DJANGO_GCP_STORAGE_BUCKET_NAME=aivus-production-media
# LLM (Vertex AI / Gemini)
# ------------------------------------------------------------------------------
# WARNING: The previously exposed OpenAI key MUST be revoked at
# https://platform.openai.com/api-keys
GOOGLE_CLOUD_PROJECT=pioneering-flag-476313-u2
GOOGLE_CLOUD_LOCATION=global
# Speech-to-Text (Vertex) — выровнено с GOOGLE_CLOUD_LOCATION (Vertex Gemini).
GOOGLE_CLOUD_SPEECH_LOCATION=us
STT_MODEL=chirp_3
STT_RECOGNIZER=aivus-chirp3-auto
STT_LANGUAGE_CODES=auto

# Optional: separate service account JSON for Vertex AI.
# If empty, Application Default Credentials are used (same SA as GCS storage).
VERTEX_CREDENTIALS_PATH=/app/vertex-credentials.json
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email (Resend)
# ------------------------------------------------------------------------------
# Оставь пустым — письма пойдут в Mailpit (http://localhost:8025).
# Вставь реальный ключ — письма пойдут через Resend на указанный адрес.
RESEND_API_KEY=
DJANGO_DEFAULT_FROM_EMAIL="Aivus <noreply@aivus.co>"

# Email agent (Stage 3): symmetric encryption key ring for stored app-passwords.
# Newest key first; add a new key at position [0] to rotate.
FERNET_KEYS=8jrkQPHoIWXFZit3aNO2rt3sMve4M9Or5yXxHa5lcog=
