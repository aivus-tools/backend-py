# General
# ------------------------------------------------------------------------------
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery
# ------------------------------------------------------------------------------

# Flower
CELERY_FLOWER_USER=admin
CELERY_FLOWER_PASSWORD=admin123

# Aivus Authentication
# ------------------------------------------------------------------------------
HMAC_SECRET=local-hmac-secret-for-development
API_KEY=local-api-key-for-development

DJANGO_DEBUG=True
DEBUG=True

# GCP Storage (optional - if empty, local filesystem will be used)
